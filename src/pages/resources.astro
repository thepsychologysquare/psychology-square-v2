---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allWorksheets = await getCollection('worksheets', ({ data }) => !data.draft);
const sorted = allWorksheets.sort((a, b) => a.data.order - b.data.order);

const categoryMeta: Record<string, string> = {
  'general': 'General',
  'anxiety': 'Anxiety',
  'depression': 'Depression',
  'adhd': 'ADHD',
  'addiction-recovery': 'Addiction & Recovery',
  'trauma': 'Trauma',
  'relationships': 'Relationships',
  'stress-burnout': 'Stress & Burnout',
};
const ageMeta: Record<string, string> = { 'children': 'Children', 'adults': 'Adults' };

const categoriesPresent = [...new Set(sorted.map((w) => w.data.category))].sort();
---

<Layout title="Resources" description="Free and paid worksheets to use between therapy sessions.">
  <section class="hero article-index-hero">
    <div class="wrap">
      <p class="eyebrow">Worksheets &amp; Guides</p>
      <h1 class="hero-title" style="font-size: clamp(32px, 4vw, 48px); margin-bottom: 16px;">Resources</h1>
      <p class="hero-sub">Printable worksheets to use on your own or bring to a session. Some are free, some are part of a paid set — request any paid worksheet and we'll follow up directly.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="toolbar">
        <input type="text" id="search-input" class="search-input" placeholder="Search worksheets…" autocomplete="off" />

        <details class="filter-dropdown" id="filter-dropdown">
          <summary class="filter-toggle">
            Filters <span class="filter-badge" id="filter-badge" hidden>0</span>
          </summary>
          <div class="filter-panel">
            <div class="filter-group">
              <h3 class="filter-heading">Tier</h3>
              <div class="checkbox-list" id="tier-filters">
                <label class="checkbox-row">
                  <input type="checkbox" value="free" class="tier-checkbox" data-label="Free" />
                  <span>Free</span>
                </label>
                <label class="checkbox-row">
                  <input type="checkbox" value="paid" class="tier-checkbox" data-label="Paid" />
                  <span>Paid</span>
                </label>
              </div>
            </div>

            <div class="filter-group">
              <h3 class="filter-heading">Topics</h3>
              <div class="checkbox-list" id="category-filters">
                {categoriesPresent.map((cat) => (
                  <label class="checkbox-row">
                    <input type="checkbox" value={cat} class="category-checkbox" data-label={categoryMeta[cat] || cat} />
                    <span>{categoryMeta[cat] || cat}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="filter-group">
              <h3 class="filter-heading">Age</h3>
              <div class="checkbox-list" id="age-filters">
                <label class="checkbox-row">
                  <input type="checkbox" value="children" class="age-checkbox" data-label="Children" />
                  <span>Children</span>
                </label>
                <label class="checkbox-row">
                  <input type="checkbox" value="adults" class="age-checkbox" data-label="Adults" />
                  <span>Adults</span>
                </label>
              </div>
            </div>

            <div class="filter-panel-actions">
              <button type="button" id="clear-filters" class="clear-filters-btn">Clear all</button>
              <button type="button" class="btn btn--primary filter-done-btn" id="filter-done">Show results</button>
            </div>
          </div>
        </details>
      </div>

      <div class="active-chips" id="active-chips"></div>

      <p class="results-count" id="results-count"></p>

      <div class="card-grid worksheet-grid" id="worksheet-grid">
        {sorted.map((w) => (
          <div
            class="article-card worksheet-card"
            data-tier={w.data.tier}
            data-category={w.data.category}
            data-age={w.data.age.join(',')}
            data-title={w.data.title.toLowerCase()}
            data-description={w.data.description.toLowerCase()}
          >
            <span class="article-meta">
              {w.data.tier === 'free' ? 'Free' : 'Paid'} · {categoryMeta[w.data.category]} · {w.data.age.map((a) => ageMeta[a]).join(' & ')}
            </span>
            <h3>{w.data.title}</h3>
            <p>{w.data.description}</p>
            {w.data.tier === 'free' ? (
              <a class="worksheet-btn worksheet-btn--download" href={w.data.fileUrl} target="_blank" rel="noopener">Download PDF →</a>
            ) : (
              <button class="worksheet-btn worksheet-btn--request request-btn" data-title={w.data.title} type="button">Request this worksheet →</button>
            )}
          </div>
        ))}
      </div>

      <p class="no-results" id="no-results" hidden>No worksheets match your filters. Try clearing some, or search a different term.</p>

      <div class="request-cta-banner">
        <p>Can't find what you're looking for?</p>
        <button type="button" class="btn btn--primary" id="openGeneralRequest">Request a worksheet →</button>
      </div>
    </div>
  </section>

  <div class="modal-overlay" id="requestModalOverlay">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <button class="modal-close" id="modalClose" aria-label="Close">✕</button>
      <h2 id="modalTitle" class="section-title" style="font-size:22px; margin-bottom:8px;">Request a worksheet</h2>
      <p style="color: var(--ink-600); margin-bottom: 24px; font-size:14px;">Fill this in and we'll follow up by email to arrange payment (for paid items) or the file itself.</p>

      <form action="https://formspree.io/f/mdaqlngp" method="POST" class="request-form">
        <label>
          Worksheet
          <input type="text" name="worksheet" id="worksheet-field" placeholder="e.g. Anger Management Workbook — or describe what you're looking for" />
        </label>
        <label>
          Your name
          <input type="text" name="name" required />
        </label>
        <label>
          Your email
          <input type="email" name="email" required />
        </label>
        <label>
          Message (optional)
          <textarea name="message" rows="3"></textarea>
        </label>
        <button type="submit" class="btn btn--primary">Send request</button>
      </form>
    </div>
  </div>
</Layout>

<style>
  .article-index-hero{ padding: 72px 0 56px; }

  .toolbar{ display:flex; gap:12px; position: relative; z-index: 20; }
  .search-input{
    flex: 1;
    font-family: var(--font-body);
    font-size: 14.5px;
    padding: 12px 16px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: var(--paper-0);
    color: var(--ink-900);
  }
  .search-input:focus{ outline: 2px solid var(--gold-500); outline-offset: 1px; }

  .filter-dropdown{ position: relative; }
  .filter-toggle{
    display:flex;
    align-items:center;
    gap:8px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--navy-950);
    background: var(--paper-0);
    border: 1px solid var(--line);
    padding: 12px 20px;
    border-radius: 3px;
    cursor: pointer;
    white-space: nowrap;
    list-style: none;
    user-select: none;
  }
  .filter-toggle::-webkit-details-marker{ display:none; }
  .filter-toggle:hover{ border-color: var(--gold-500); }
  .filter-dropdown[open] .filter-toggle{ border-color: var(--navy-950); background: var(--navy-950); color: var(--paper-0); }

  .filter-badge{
    background: var(--gold-500);
    color: var(--navy-950);
    font-size: 11px;
    font-weight: 700;
    border-radius: 999px;
    padding: 1px 7px;
    min-width: 18px;
    text-align: center;
  }

  .filter-panel{
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: min(360px, calc(100vw - 64px));
    max-height: 60vh;
    overflow-y: auto;
    background: var(--paper-0);
    border: 1px solid var(--line);
    border-radius: 4px;
    box-shadow: 0 12px 32px rgba(19,26,34,0.14);
    padding: 22px;
    display:flex;
    flex-direction: column;
    gap: 22px;
  }

  .filter-group{ display:flex; flex-direction:column; gap:10px; }
  .filter-heading{
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-600);
  }
  .checkbox-list{ display:flex; flex-direction:column; gap:10px; }
  .checkbox-row{
    display:flex;
    align-items:center;
    gap:9px;
    font-size: 14px;
    color: var(--ink-900);
    cursor: pointer;
  }
  .checkbox-row input{ accent-color: var(--gold-500); width:15px; height:15px; flex:none; }

  .filter-panel-actions{
    display:flex;
    justify-content: space-between;
    align-items:center;
    padding-top: 6px;
    border-top: 1px solid var(--line);
  }
  .clear-filters-btn{
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-600);
    background: none;
    border: none;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    padding: 0;
  }
  .clear-filters-btn:hover{ color: var(--gold-500); }
  .filter-done-btn{ font-size: 13px; padding: 10px 20px; }

  .active-chips{ display:flex; flex-wrap:wrap; gap:8px; margin-top: 18px; }
  .active-chips:empty{ margin-top: 0; }
  .active-chip{
    display:flex;
    align-items:center;
    gap:7px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.02em;
    color: var(--navy-950);
    background: var(--paper-50);
    border: 1px solid var(--line);
    padding: 6px 10px 6px 14px;
    border-radius: 999px;
  }
  .active-chip button{
    background: none; border: none; color: var(--ink-600);
    cursor: pointer; font-size: 14px; line-height: 1; padding: 2px;
  }
  .active-chip button:hover{ color: var(--gold-500); }

  .results-count{
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--ink-600);
    margin: 24px 0;
  }
  .no-results{ color: var(--ink-600); padding: 40px 0; }

  .worksheet-card{ justify-content: flex-start; }
  .worksheet-card.is-hidden{ display: none; }

  .request-form{ display:flex; flex-direction:column; gap:18px; }
  .request-form label{ display:flex; flex-direction:column; gap:6px; font-size: 14px; color: var(--ink-600); font-weight: 500; }
  .request-form input,
  .request-form textarea{
    font-family: var(--font-body);
    font-size: 15px;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: var(--paper-0);
    color: var(--ink-900);
  }
  .request-form input:focus,
  .request-form textarea:focus{ outline: 2px solid var(--gold-500); outline-offset: 1px; }
  .request-form button{ align-self: flex-start; border: none; cursor: pointer; }

  @media (max-width: 600px){
    .toolbar{ flex-direction: column; }
    .filter-panel{ right: 0; left: 0; width: auto; }
    .request-cta-banner{ flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  type FilterEntry = { type: 'tier' | 'category' | 'age'; value: string; label: string };

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const filterDropdown = document.getElementById('filter-dropdown') as HTMLDetailsElement;
  const filterBadge = document.getElementById('filter-badge') as HTMLElement;
  const tierCheckboxes = document.querySelectorAll<HTMLInputElement>('.tier-checkbox');
  const categoryCheckboxes = document.querySelectorAll<HTMLInputElement>('.category-checkbox');
  const ageCheckboxes = document.querySelectorAll<HTMLInputElement>('.age-checkbox');
  const clearBtn = document.getElementById('clear-filters');
  const doneBtn = document.getElementById('filter-done');
  const cards = document.querySelectorAll<HTMLElement>('#worksheet-grid .worksheet-card');
  const resultsCount = document.getElementById('results-count');
  const noResults = document.getElementById('no-results');
  const activeChipsContainer = document.getElementById('active-chips');

  function getActiveFilters(): FilterEntry[] {
    const tiers = [...tierCheckboxes].filter((c) => c.checked).map((c) => ({ type: 'tier' as const, value: c.value, label: c.dataset.label || c.value }));
    const cats = [...categoryCheckboxes].filter((c) => c.checked).map((c) => ({ type: 'category' as const, value: c.value, label: c.dataset.label || c.value }));
    const ages = [...ageCheckboxes].filter((c) => c.checked).map((c) => ({ type: 'age' as const, value: c.value, label: c.dataset.label || c.value }));
    return [...tiers, ...cats, ...ages];
  }

  function renderChips() {
    if (!activeChipsContainer) return;
    const active = getActiveFilters();
    activeChipsContainer.innerHTML = '';
    active.forEach((f) => {
      const chip = document.createElement('span');
      chip.className = 'active-chip';
      chip.innerHTML = `${f.label} <button type="button" aria-label="Remove filter">✕</button>`;
      chip.querySelector('button')?.addEventListener('click', () => {
        const source = f.type === 'tier' ? tierCheckboxes : f.type === 'category' ? categoryCheckboxes : ageCheckboxes;
        source.forEach((c) => { if (c.value === f.value) c.checked = false; });
        applyFilters();
      });
      activeChipsContainer.appendChild(chip);
    });
    if (filterBadge) {
      filterBadge.hidden = active.length === 0;
      filterBadge.textContent = String(active.length);
    }
  }

  function applyFilters() {
    const query = searchInput.value.trim().toLowerCase();
    const activeTiers = [...tierCheckboxes].filter((c) => c.checked).map((c) => c.value);
    const activeCategories = [...categoryCheckboxes].filter((c) => c.checked).map((c) => c.value);
    const activeAges = [...ageCheckboxes].filter((c) => c.checked).map((c) => c.value);

    let visibleCount = 0;

    cards.forEach((card) => {
      const title = card.dataset.title || '';
      const description = card.dataset.description || '';
      const tier = card.dataset.tier || '';
      const category = card.dataset.category || '';
      const ages = (card.dataset.age || '').split(',').filter(Boolean);

      const matchesSearch = !query || title.includes(query) || description.includes(query);
      const matchesTier = activeTiers.length === 0 || activeTiers.includes(tier);
      const matchesCategory = activeCategories.length === 0 || activeCategories.includes(category);
      const matchesAge = activeAges.length === 0 || activeAges.some((a) => ages.includes(a));

      const show = matchesSearch && matchesTier && matchesCategory && matchesAge;
      card.classList.toggle('is-hidden', !show);
      if (show) visibleCount++;
    });

    if (resultsCount) {
      resultsCount.textContent = `Showing ${visibleCount} of ${cards.length} worksheet${cards.length === 1 ? '' : 's'}`;
    }
    if (noResults) noResults.hidden = visibleCount !== 0;

    renderChips();
  }

  searchInput.addEventListener('input', applyFilters);
  tierCheckboxes.forEach((cb) => cb.addEventListener('change', applyFilters));
  categoryCheckboxes.forEach((cb) => cb.addEventListener('change', applyFilters));
  ageCheckboxes.forEach((cb) => cb.addEventListener('change', applyFilters));

  clearBtn?.addEventListener('click', () => {
    searchInput.value = '';
    tierCheckboxes.forEach((cb) => (cb.checked = false));
    categoryCheckboxes.forEach((cb) => (cb.checked = false));
    ageCheckboxes.forEach((cb) => (cb.checked = false));
    applyFilters();
  });

  doneBtn?.addEventListener('click', () => { filterDropdown.open = false; });
  document.addEventListener('click', (e) => {
    if (filterDropdown.open && !filterDropdown.contains(e.target as Node)) filterDropdown.open = false;
  });

  const urlFilter = new URLSearchParams(window.location.search).get('filter');
  if (urlFilter === 'free' || urlFilter === 'paid') {
    const match = [...tierCheckboxes].find((c) => c.value === urlFilter);
    if (match) match.checked = true;
  }
  applyFilters();

  // Modal
  const modalOverlay = document.getElementById('requestModalOverlay');
  const modalClose = document.getElementById('modalClose');
  const worksheetField = document.getElementById('worksheet-field') as HTMLInputElement | null;

  function openModal(prefill = '') {
    if (worksheetField) worksheetField.value = prefill;
    modalOverlay?.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    modalOverlay?.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.request-btn').forEach((btn) => {
    btn.addEventListener('click', () => openModal(btn.dataset.title || ''));
  });
  document.getElementById('openGeneralRequest')?.addEventListener('click', () => openModal(''));
  modalClose?.addEventListener('click', closeModal);
  modalOverlay?.addEventListener('click', (e) => { if (e.target === modalOverlay) closeModal(); });
</script>
