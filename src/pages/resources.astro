---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allWorksheets = await getCollection('worksheets', ({ data }) => !data.draft);
const sorted = allWorksheets.sort((a, b) => a.data.order - b.data.order);

const categoryMeta: Record<string, string> = {
  'general': 'General',
  'anxiety': 'Anxiety',
  'depression': 'Depression',
  'adhd': 'ADHD',
  'addiction-recovery': 'Addiction & Recovery',
  'trauma': 'Trauma',
  'relationships': 'Relationships',
  'stress-burnout': 'Stress & Burnout',
};

// Auto-derived from actual content, so new categories need zero page edits.
const categoriesPresent = [...new Set(sorted.map((w) => w.data.category))].sort();
---

<Layout title="Resources" description="Free and paid worksheets to use between therapy sessions.">
  <section class="hero article-index-hero">
    <div class="wrap">
      <p class="eyebrow">Worksheets &amp; Guides</p>
      <h1 class="hero-title" style="font-size: clamp(32px, 4vw, 48px); margin-bottom: 16px;">Resources</h1>
      <p class="hero-sub">Printable worksheets to use on your own or bring to a session. Some are free, some are part of a paid set — request any paid worksheet and we'll follow up directly.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="search-layout">
        <aside class="filter-panel">
          <div class="filter-block">
            <input type="text" id="search-input" class="search-input" placeholder="Search worksheets…" autocomplete="off" />
          </div>

          <div class="filter-block">
            <h3 class="filter-heading">Tier</h3>
            <div class="checkbox-list">
              <label class="checkbox-row">
                <input type="checkbox" value="free" class="tier-checkbox" />
                <span>Free</span>
              </label>
              <label class="checkbox-row">
                <input type="checkbox" value="paid" class="tier-checkbox" />
                <span>Paid</span>
              </label>
            </div>
          </div>

          <div class="filter-block">
            <h3 class="filter-heading">Category</h3>
            <div class="checkbox-list">
              {categoriesPresent.map((cat) => (
                <label class="checkbox-row">
                  <input type="checkbox" value={cat} class="category-checkbox" />
                  <span>{categoryMeta[cat] || cat}</span>
                </label>
              ))}
            </div>
          </div>

          <button type="button" id="clear-filters" class="clear-filters-btn">Clear all filters</button>
        </aside>

        <div class="results-area">
          <p class="results-count" id="results-count"></p>

          <div class="card-grid worksheet-grid" id="worksheet-grid">
            {sorted.map((w) => (
              <div
                class="article-card worksheet-card"
                data-tier={w.data.tier}
                data-category={w.data.category}
                data-title={w.data.title.toLowerCase()}
                data-description={w.data.description.toLowerCase()}
              >
                <span class="article-meta">
                  {w.data.tier === 'free' ? 'Free' : 'Paid'} · {categoryMeta[w.data.category]}
                </span>
                <h3>{w.data.title}</h3>
                <p>{w.data.description}</p>
                {w.data.tier === 'free' ? (
                  <a class="btn btn--text worksheet-action" href={w.data.fileUrl} target="_blank" rel="noopener">Download PDF →</a>
                ) : (
                  <button class="btn btn--text worksheet-action request-btn" data-title={w.data.title} type="button">Request this worksheet →</button>
                )}
              </div>
            ))}
          </div>

          <p class="no-results" id="no-results" hidden>No worksheets match your filters. Try clearing some, or search a different term.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt" id="request-form">
    <div class="wrap" style="max-width: 560px;">
      <div class="section-head" style="margin-bottom: 24px;">
        <h2 class="section-title">Request a worksheet</h2>
      </div>
      <p style="color: var(--ink-600); margin-bottom: 28px;">Fill this in and we'll follow up by email to arrange payment and send the file.</p>

      <form action="https://formspree.io/f/mdaqlngp" method="POST" class="request-form">
        <label>
          Worksheet
          <input type="text" name="worksheet" id="worksheet-field" readonly />
        </label>
        <label>
          Your name
          <input type="text" name="name" required />
        </label>
        <label>
          Your email
          <input type="email" name="email" required />
        </label>
        <label>
          Message (optional)
          <textarea name="message" rows="3"></textarea>
        </label>
        <button type="submit" class="btn btn--primary">Send request</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .article-index-hero{ padding: 72px 0 56px; }

  .search-layout{
    display:grid;
    grid-template-columns: 240px 1fr;
    gap: 44px;
    align-items: start;
  }

  .filter-panel{
    position: sticky;
    top: 96px;
    display:flex;
    flex-direction:column;
    gap:28px;
  }
  .filter-block{ display:flex; flex-direction:column; gap:10px; }

  .search-input{
    font-family: var(--font-body);
    font-size: 14.5px;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: var(--paper-0);
    color: var(--ink-900);
    width: 100%;
  }
  .search-input:focus{
    outline: 2px solid var(--gold-500);
    outline-offset: 1px;
  }

  .filter-heading{
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-600);
  }

  .checkbox-list{ display:flex; flex-direction:column; gap:10px; }
  .checkbox-row{
    display:flex;
    align-items:center;
    gap:9px;
    font-size: 14px;
    color: var(--ink-900);
    cursor: pointer;
  }
  .checkbox-row input{ accent-color: var(--gold-500); width:15px; height:15px; }

  .clear-filters-btn{
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-600);
    background: none;
    border: none;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    text-align: left;
    padding: 0;
  }
  .clear-filters-btn:hover{ color: var(--gold-500); }

  .results-count{
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--ink-600);
    margin-bottom: 24px;
  }

  .no-results{ color: var(--ink-600); padding: 40px 0; }

  .worksheet-card{ justify-content: flex-start; }
  .worksheet-card.is-hidden{ display: none; }
  .worksheet-action{ margin-top: auto; align-self: flex-start; }
  .request-btn{
    background: none;
    border: none;
    font-family: inherit;
    padding: 13px 4px;
  }

  .request-form{
    display:flex;
    flex-direction:column;
    gap:18px;
  }
  .request-form label{
    display:flex;
    flex-direction:column;
    gap:6px;
    font-size: 14px;
    color: var(--ink-600);
    font-weight: 500;
  }
  .request-form input,
  .request-form textarea{
    font-family: var(--font-body);
    font-size: 15px;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: var(--paper-0);
    color: var(--ink-900);
  }
  .request-form input:focus,
  .request-form textarea:focus{
    outline: 2px solid var(--gold-500);
    outline-offset: 1px;
  }
  .request-form button{ align-self: flex-start; border: none; cursor: pointer; }

  @media (max-width: 860px){
    .search-layout{ grid-template-columns: 1fr; }
    .filter-panel{ position: static; }
  }
</style>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const tierCheckboxes = document.querySelectorAll<HTMLInputElement>('.tier-checkbox');
  const categoryCheckboxes = document.querySelectorAll<HTMLInputElement>('.category-checkbox');
  const clearBtn = document.getElementById('clear-filters');
  const cards = document.querySelectorAll<HTMLElement>('#worksheet-grid .worksheet-card');
  const resultsCount = document.getElementById('results-count');
  const noResults = document.getElementById('no-results');

  function applyFilters() {
    const query = searchInput.value.trim().toLowerCase();
    const activeTiers = [...tierCheckboxes].filter((c) => c.checked).map((c) => c.value);
    const activeCategories = [...categoryCheckboxes].filter((c) => c.checked).map((c) => c.value);

    let visibleCount = 0;

    cards.forEach((card) => {
      const title = card.dataset.title || '';
      const description = card.dataset.description || '';
      const tier = card.dataset.tier || '';
      const category = card.dataset.category || '';

      const matchesSearch = !query || title.includes(query) || description.includes(query);
      const matchesTier = activeTiers.length === 0 || activeTiers.includes(tier);
      const matchesCategory = activeCategories.length === 0 || activeCategories.includes(category);

      const show = matchesSearch && matchesTier && matchesCategory;
      card.classList.toggle('is-hidden', !show);
      if (show) visibleCount++;
    });

    if (resultsCount) {
      resultsCount.textContent = `Showing ${visibleCount} of ${cards.length} worksheet${cards.length === 1 ? '' : 's'}`;
    }
    if (noResults) {
      noResults.hidden = visibleCount !== 0;
    }
  }

  searchInput.addEventListener('input', applyFilters);
  tierCheckboxes.forEach((cb) => cb.addEventListener('change', applyFilters));
  categoryCheckboxes.forEach((cb) => cb.addEventListener('change', applyFilters));

  clearBtn?.addEventListener('click', () => {
    searchInput.value = '';
    tierCheckboxes.forEach((cb) => (cb.checked = false));
    categoryCheckboxes.forEach((cb) => (cb.checked = false));
    applyFilters();
  });

  // Support ?filter=free / ?filter=paid links from the nav mega-menu
  const urlFilter = new URLSearchParams(window.location.search).get('filter');
  if (urlFilter === 'free' || urlFilter === 'paid') {
    const match = [...tierCheckboxes].find((c) => c.value === urlFilter);
    if (match) match.checked = true;
  }

  applyFilters();

  const requestButtons = document.querySelectorAll<HTMLButtonElement>('.request-btn');
  const worksheetField = document.getElementById('worksheet-field') as HTMLInputElement | null;

  requestButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      if (worksheetField) {
        worksheetField.value = btn.dataset.title || '';
      }
      document.getElementById('request-form')?.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>