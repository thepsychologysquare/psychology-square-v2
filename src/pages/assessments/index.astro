---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allAssessments = await getCollection('assessments', ({ data }) => !data.draft);
const sorted = allAssessments.sort((a, b) => a.data.order - b.data.order);

const categoryMeta: Record<string, string> = {
  'general': 'General',
  'anxiety': 'Anxiety',
  'depression': 'Depression',
  'adhd': 'ADHD',
  'addiction-recovery': 'Addiction & Recovery',
  'trauma': 'Trauma',
  'relationships': 'Relationships',
  'stress-burnout': 'Stress & Burnout',
};
const ageMeta: Record<string, string> = { 'children': 'Children', 'adults': 'Adults' };
const categoriesPresent = [...new Set(sorted.map((a) => a.data.category))].sort();
---

<Layout title="Assessments" description="Publicly available psychological scales and assessment tools, with scoring guidance.">
  <section class="hero article-index-hero">
    <div class="wrap">
      <p class="eyebrow">Scales &amp; Tools</p>
      <h1 class="hero-title" style="font-size: clamp(32px, 4vw, 48px); margin-bottom: 16px;">Assessments</h1>
      <p class="hero-sub">Publicly available screening scales, with a plain-language description and scoring guide for each. These are screening tools, not diagnoses — always interpret alongside a clinician.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="toolbar">
        <input type="text" id="search-input" class="search-input" placeholder="Search assessments…" autocomplete="off" />

        <details class="filter-dropdown" id="filter-dropdown">
          <summary class="filter-toggle">
            Filters <span class="filter-badge" id="filter-badge" hidden>0</span>
          </summary>
          <div class="filter-panel">
            <div class="filter-group">
              <h3 class="filter-heading">Topics</h3>
              <div class="checkbox-list" id="category-filters">
                {categoriesPresent.map((cat) => (
                  <label class="checkbox-row">
                    <input type="checkbox" value={cat} class="category-checkbox" data-label={categoryMeta[cat] || cat} />
                    <span>{categoryMeta[cat] || cat}</span>
                  </label>
                ))}
              </div>
            </div>
            <div class="filter-group">
              <h3 class="filter-heading">Age</h3>
              <div class="checkbox-list" id="age-filters">
                <label class="checkbox-row">
                  <input type="checkbox" value="children" class="age-checkbox" data-label="Children" />
                  <span>Children</span>
                </label>
                <label class="checkbox-row">
                  <input type="checkbox" value="adults" class="age-checkbox" data-label="Adults" />
                  <span>Adults</span>
                </label>
              </div>
            </div>
            <div class="filter-panel-actions">
              <button type="button" id="clear-filters" class="clear-filters-btn">Clear all</button>
              <button type="button" class="btn btn--primary filter-done-btn" id="filter-done">Show results</button>
            </div>
          </div>
        </details>
      </div>

      <div class="active-chips" id="active-chips"></div>
      <p class="results-count" id="results-count"></p>

      <div class="assessment-list" id="assessment-list">
        {sorted.map((a) => (
          <div
            class="assessment-card"
            data-category={a.data.category}
            data-age={a.data.age.join(',')}
            data-title={a.data.title.toLowerCase()}
            data-description={a.data.description.toLowerCase()}
          >
            <div class="assessment-card-main">
              <span class="article-meta">{categoryMeta[a.data.category]} · {a.data.age.map((x) => ageMeta[x]).join(' & ')}</span>
              <h3>{a.data.title}</h3>
              <p>{a.data.description}</p>
              {a.data.sourceNote && <p class="assessment-source">{a.data.sourceNote}</p>}
            </div>
            <div class="assessment-card-side">
              <a class="worksheet-btn worksheet-btn--download" href={a.data.pdfUrl} target="_blank" rel="noopener noreferrer">View PDF →</a>
              <details class="scoring-details">
                <summary>How to score</summary>
                <p>{a.data.scoringSummary}</p>
              </details>
            </div>
          </div>
        ))}
      </div>

      <p class="no-results" id="no-results" hidden>No assessments match your filters. Try clearing some, or search a different term.</p>
    </div>
  </section>
</Layout>

<style>
  .article-index-hero{ padding: 72px 0 56px; }

  .toolbar{ display:flex; gap:12px; position: relative; z-index: 20; }
  .search-input{
    flex: 1;
    font-family: var(--font-body);
    font-size: 14.5px;
    padding: 12px 16px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: var(--paper-0);
    color: var(--ink-900);
  }
  .search-input:focus{ outline: 2px solid var(--gold-500); outline-offset: 1px; }

  .filter-dropdown{ position: relative; }
  .filter-toggle{
    display:flex; align-items:center; gap:8px;
    font-family: var(--font-mono); font-size: 13px; letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--navy-950); background: var(--paper-0); border: 1px solid var(--line);
    padding: 12px 20px; border-radius: 3px; cursor: pointer; white-space: nowrap; list-style: none; user-select: none;
  }
  .filter-toggle::-webkit-details-marker{ display:none; }
  .filter-toggle:hover{ border-color: var(--gold-500); }
  .filter-dropdown[open] .filter-toggle{ border-color: var(--navy-950); background: var(--navy-950); color: var(--paper-0); }
  .filter-badge{
    background: var(--gold-500); color: var(--navy-950); font-size: 11px; font-weight: 700;
    border-radius: 999px; padding: 1px 7px; min-width: 18px; text-align: center;
  }
  .filter-panel{
    position: absolute; top: calc(100% + 8px); right: 0;
    width: min(360px, calc(100vw - 64px)); max-height: 60vh; overflow-y: auto;
    background: var(--paper-0); border: 1px solid var(--line); border-radius: 4px;
    box-shadow: 0 12px 32px rgba(19,26,34,0.14); padding: 22px;
    display:flex; flex-direction: column; gap: 22px;
  }
  .filter-group{ display:flex; flex-direction:column; gap:10px; }
  .filter-heading{ font-family: var(--font-mono); font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-600); }
  .checkbox-list{ display:flex; flex-direction:column; gap:10px; }
  .checkbox-row{ display:flex; align-items:center; gap:9px; font-size: 14px; color: var(--ink-900); cursor: pointer; }
  .checkbox-row input{ accent-color: var(--gold-500); width:15px; height:15px; flex:none; }
  .filter-panel-actions{ display:flex; justify-content: space-between; align-items:center; padding-top: 6px; border-top: 1px solid var(--line); }
  .clear-filters-btn{ font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-600); background: none; border: none; text-decoration: underline; text-underline-offset: 3px; cursor: pointer; padding: 0; }
  .clear-filters-btn:hover{ color: var(--gold-500); }
  .filter-done-btn{ font-size: 13px; padding: 10px 20px; }

  .active-chips{ display:flex; flex-wrap:wrap; gap:8px; margin-top: 18px; }
  .active-chips:empty{ margin-top: 0; }
  .active-chip{ display:flex; align-items:center; gap:7px; font-family: var(--font-mono); font-size: 12px; color: var(--navy-950); background: var(--paper-50); border: 1px solid var(--line); padding: 6px 10px 6px 14px; border-radius: 999px; }
  .active-chip button{ background: none; border: none; color: var(--ink-600); cursor: pointer; font-size: 14px; line-height: 1; padding: 2px; }
  .active-chip button:hover{ color: var(--gold-500); }

  .results-count{ font-family: var(--font-mono); font-size: 12.5px; color: var(--ink-600); margin: 24px 0; }
  .no-results{ color: var(--ink-600); padding: 40px 0; }

  .assessment-list{ display:flex; flex-direction:column; gap:16px; }
  .assessment-card{
    display:flex;
    justify-content:space-between;
    gap:24px;
    background: var(--paper-0);
    border: 1px solid var(--line);
    padding: 24px 28px;
    transition: border-color .25s var(--ease);
  }
  .assessment-card:hover{ border-color: var(--gold-500); }
  .assessment-card.is-hidden{ display:none; }
  .assessment-card-main{ flex: 1; }
  .assessment-card-main h3{ font-size: 18px; margin: 6px 0 8px; }
  .assessment-card-main p{ color: var(--ink-600); font-size: 14.5px; }
  .assessment-source{ font-size: 12px !important; margin-top: 8px; color: var(--sage-500) !important; }
  .assessment-card-side{ display:flex; flex-direction:column; gap:10px; align-items:flex-start; min-width: 200px; }

  .scoring-details{ width: 100%; }
  .scoring-details summary{
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.03em; text-transform: uppercase;
    color: var(--navy-700); cursor: pointer; list-style:none; padding: 4px 0;
  }
  .scoring-details summary::-webkit-details-marker{ display:none; }
  .scoring-details summary:hover{ color: var(--gold-500); }
  .scoring-details p{ font-size: 13.5px; color: var(--ink-600); margin-top: 8px; line-height: 1.6; }

  @media (max-width: 700px){
    .toolbar{ flex-direction: column; }
    .filter-panel{ right: 0; left: 0; width: auto; }
    .assessment-card{ flex-direction: column; }
    .assessment-card-side{ min-width: 0; }
  }
</style>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const filterDropdown = document.getElementById('filter-dropdown') as HTMLDetailsElement;
  const filterBadge = document.getElementById('filter-badge') as HTMLElement;
  const categoryCheckboxes = document.querySelectorAll<HTMLInputElement>('.category-checkbox');
  const ageCheckboxes = document.querySelectorAll<HTMLInputElement>('.age-checkbox');
  const clearBtn = document.getElementById('clear-filters');
  const doneBtn = document.getElementById('filter-done');
  const cards = document.querySelectorAll<HTMLElement>('#assessment-list .assessment-card');
  const resultsCount = document.getElementById('results-count');
  const noResults = document.getElementById('no-results');
  const activeChipsContainer = document.getElementById('active-chips');

  type FilterEntry = { type: 'category' | 'age'; value: string; label: string };

  function getActiveFilters(): FilterEntry[] {
    const cats = [...categoryCheckboxes].filter((c) => c.checked).map((c) => ({ type: 'category' as const, value: c.value, label: c.dataset.label || c.value }));
    const ages = [...ageCheckboxes].filter((c) => c.checked).map((c) => ({ type: 'age' as const, value: c.value, label: c.dataset.label || c.value }));
    return [...cats, ...ages];
  }

  function renderChips() {
    if (!activeChipsContainer) return;
    const active = getActiveFilters();
    activeChipsContainer.innerHTML = '';
    active.forEach((f) => {
      const chip = document.createElement('span');
      chip.className = 'active-chip';
      chip.innerHTML = `${f.label} <button type="button" aria-label="Remove filter">✕</button>`;
      chip.querySelector('button')?.addEventListener('click', () => {
        const source = f.type === 'category' ? categoryCheckboxes : ageCheckboxes;
        source.forEach((c) => { if (c.value === f.value) c.checked = false; });
        applyFilters();
      });
      activeChipsContainer.appendChild(chip);
    });
    if (filterBadge) {
      filterBadge.hidden = active.length === 0;
      filterBadge.textContent = String(active.length);
    }
  }

  function applyFilters() {
    const query = searchInput.value.trim().toLowerCase();
    const activeCategories = [...categoryCheckboxes].filter((c) => c.checked).map((c) => c.value);
    const activeAges = [...ageCheckboxes].filter((c) => c.checked).map((c) => c.value);

    let visibleCount = 0;
    cards.forEach((card) => {
      const title = card.dataset.title || '';
      const description = card.dataset.description || '';
      const category = card.dataset.category || '';
      const ages = (card.dataset.age || '').split(',').filter(Boolean);

      const matchesSearch = !query || title.includes(query) || description.includes(query);
      const matchesCategory = activeCategories.length === 0 || activeCategories.includes(category);
      const matchesAge = activeAges.length === 0 || activeAges.some((a) => ages.includes(a));

      const show = matchesSearch && matchesCategory && matchesAge;
      card.classList.toggle('is-hidden', !show);
      if (show) visibleCount++;
    });

    if (resultsCount) resultsCount.textContent = `Showing ${visibleCount} of ${cards.length} assessment${cards.length === 1 ? '' : 's'}`;
    if (noResults) noResults.hidden = visibleCount !== 0;
    renderChips();
  }

  searchInput.addEventListener('input', applyFilters);
  categoryCheckboxes.forEach((cb) => cb.addEventListener('change', applyFilters));
  ageCheckboxes.forEach((cb) => cb.addEventListener('change', applyFilters));

  clearBtn?.addEventListener('click', () => {
    searchInput.value = '';
    categoryCheckboxes.forEach((cb) => (cb.checked = false));
    ageCheckboxes.forEach((cb) => (cb.checked = false));
    applyFilters();
  });

  doneBtn?.addEventListener('click', () => { filterDropdown.open = false; });
  document.addEventListener('click', (e) => {
    if (filterDropdown.open && !filterDropdown.contains(e.target as Node)) filterDropdown.open = false;
  });

  applyFilters();
</script>
