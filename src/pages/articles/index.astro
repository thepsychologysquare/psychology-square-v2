---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const categoryMeta: Record<string, string> = {
  'anxiety': 'Anxiety',
  'depression': 'Depression',
  'adhd': 'ADHD',
  'addiction-recovery': 'Addiction & Recovery',
  'trauma': 'Trauma',
  'relationships': 'Relationships',
  'stress-burnout': 'Stress & Burnout',
};

// Auto-derived from actual content — adding a category or tag later needs zero page edits.
const categoriesPresent = [...new Set(sorted.map((a) => a.data.category))].sort();
const tagsPresent = [...new Set(sorted.flatMap((a) => a.data.tags))].sort();
---

<Layout title="Articles" description="Articles on anxiety, depression, ADHD, trauma, relationships, and more — written and reviewed by licensed clinical psychologists.">
  <section class="hero article-index-hero">
    <div class="wrap">
      <p class="eyebrow">From the Practice</p>
      <h1 class="hero-title" style="font-size: clamp(32px, 4vw, 48px); margin-bottom: 16px;">Articles</h1>
      <p class="hero-sub">Grounded, clinically-reviewed writing on anxiety, depression, ADHD, trauma, relationships, and more — no generic advice.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="toolbar">
        <input type="text" id="search-input" class="search-input" placeholder="Search articles…" autocomplete="off" />

        <details class="filter-dropdown" id="filter-dropdown">
          <summary class="filter-toggle">
            Filters <span class="filter-badge" id="filter-badge" hidden>0</span>
          </summary>
          <div class="filter-panel">
            <div class="filter-group">
              <h3 class="filter-heading">Category</h3>
              <div class="checkbox-list" id="category-filters">
                {categoriesPresent.map((cat) => (
                  <label class="checkbox-row">
                    <input type="checkbox" value={cat} class="category-checkbox" data-label={categoryMeta[cat] || cat} />
                    <span>{categoryMeta[cat] || cat}</span>
                  </label>
                ))}
              </div>
            </div>

            {tagsPresent.length > 0 && (
              <div class="filter-group">
                <h3 class="filter-heading">Tags</h3>
                <div class="checkbox-list" id="tag-filters">
                  {tagsPresent.map((tag) => (
                    <label class="checkbox-row">
                      <input type="checkbox" value={tag} class="tag-checkbox" data-label={tag} />
                      <span>{tag}</span>
                    </label>
                  ))}
                </div>
              </div>
            )}

            <div class="filter-panel-actions">
              <button type="button" id="clear-filters" class="clear-filters-btn">Clear all</button>
              <button type="button" class="btn btn--primary filter-done-btn" id="filter-done">Show results</button>
            </div>
          </div>
        </details>
      </div>

      <div class="active-chips" id="active-chips"></div>

      <p class="results-count" id="results-count"></p>

      <div class="card-grid" id="article-grid">
        {sorted.map((article) => (
          <a
            class="article-card"
            href={`/articles/${article.id}`}
            data-title={article.data.title.toLowerCase()}
            data-description={article.data.description.toLowerCase()}
            data-category={article.data.category}
            data-tags={article.data.tags.join(',')}
          >
            <span class="article-meta">{categoryMeta[article.data.category] || article.data.category}</span>
            <h3>{article.data.title}</h3>
            <p>{article.data.description}</p>
          </a>
        ))}
      </div>

      <p class="no-results" id="no-results" hidden>No articles match your filters. Try clearing some, or search a different term.</p>
    </div>
  </section>
</Layout>

<style>
  .article-index-hero{ padding: 72px 0 56px; }

  .toolbar{
    display:flex;
    gap:12px;
    position: relative;
    z-index: 20;
  }
  .search-input{
    flex: 1;
    font-family: var(--font-body);
    font-size: 14.5px;
    padding: 12px 16px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: var(--paper-0);
    color: var(--ink-900);
  }
  .search-input:focus{ outline: 2px solid var(--gold-500); outline-offset: 1px; }

  .filter-dropdown{ position: relative; }
  .filter-toggle{
    display:flex;
    align-items:center;
    gap:8px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--navy-950);
    background: var(--paper-0);
    border: 1px solid var(--line);
    padding: 12px 20px;
    border-radius: 3px;
    cursor: pointer;
    white-space: nowrap;
    list-style: none;
    user-select: none;
  }
  .filter-toggle::-webkit-details-marker{ display:none; }
  .filter-toggle:hover{ border-color: var(--gold-500); }
  .filter-dropdown[open] .filter-toggle{ border-color: var(--navy-950); background: var(--navy-950); color: var(--paper-0); }

  .filter-badge{
    background: var(--gold-500);
    color: var(--navy-950);
    font-size: 11px;
    font-weight: 700;
    border-radius: 999px;
    padding: 1px 7px;
    min-width: 18px;
    text-align: center;
  }

  .filter-panel{
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: min(360px, calc(100vw - 64px));
    max-height: 60vh;
    overflow-y: auto;
    background: var(--paper-0);
    border: 1px solid var(--line);
    border-radius: 4px;
    box-shadow: 0 12px 32px rgba(19,26,34,0.14);
    padding: 22px;
    display:flex;
    flex-direction: column;
    gap: 22px;
  }

  .filter-group{ display:flex; flex-direction:column; gap:10px; }
  .filter-heading{
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-600);
  }
  .checkbox-list{ display:flex; flex-direction:column; gap:10px; }
  .checkbox-row{
    display:flex;
    align-items:center;
    gap:9px;
    font-size: 14px;
    color: var(--ink-900);
    cursor: pointer;
  }
  .checkbox-row input{ accent-color: var(--gold-500); width:15px; height:15px; flex:none; }
  .checkbox-row.is-extra{ display: none; }
  .checkbox-row.is-extra.is-shown{ display: flex; }

  .show-more-btn{
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--sage-500);
    background: none;
    border: none;
    text-align: left;
    padding: 0;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .filter-panel-actions{
    display:flex;
    justify-content: space-between;
    align-items:center;
    padding-top: 6px;
    border-top: 1px solid var(--line);
  }
  .clear-filters-btn{
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-600);
    background: none;
    border: none;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    padding: 0;
  }
  .clear-filters-btn:hover{ color: var(--gold-500); }
  .filter-done-btn{ font-size: 13px; padding: 10px 20px; }

  .active-chips{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    margin-top: 18px;
  }
  .active-chips:empty{ margin-top: 0; }
  .active-chip{
    display:flex;
    align-items:center;
    gap:7px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.02em;
    color: var(--navy-950);
    background: var(--paper-50);
    border: 1px solid var(--line);
    padding: 6px 10px 6px 14px;
    border-radius: 999px;
  }
  .active-chip button{
    background: none;
    border: none;
    color: var(--ink-600);
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    padding: 2px;
  }
  .active-chip button:hover{ color: var(--gold-500); }

  .results-count{
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--ink-600);
    margin: 24px 0;
  }
  .no-results{ color: var(--ink-600); padding: 40px 0; }
  .article-card.is-hidden{ display:none; }

  @media (max-width: 600px){
    .toolbar{ flex-direction: column; }
    .filter-panel{ right: 0; left: 0; width: auto; }
  }
</style>

<script>
  type FilterEntry = { type: 'category' | 'tag'; value: string; label: string };

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const filterDropdown = document.getElementById('filter-dropdown') as HTMLDetailsElement;
  const filterBadge = document.getElementById('filter-badge') as HTMLElement;
  const categoryCheckboxes = document.querySelectorAll<HTMLInputElement>('.category-checkbox');
  const tagCheckboxes = document.querySelectorAll<HTMLInputElement>('.tag-checkbox');
  const clearBtn = document.getElementById('clear-filters');
  const doneBtn = document.getElementById('filter-done');
  const cards = document.querySelectorAll<HTMLElement>('#article-grid .article-card');
  const resultsCount = document.getElementById('results-count');
  const noResults = document.getElementById('no-results');
  const activeChipsContainer = document.getElementById('active-chips');

  // Collapse long checkbox lists behind a "show more" toggle.
  function setupShowMore(containerId: string, threshold = 8) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const rows = [...container.querySelectorAll('.checkbox-row')];
    if (rows.length <= threshold) return;
    rows.slice(threshold).forEach((row) => row.classList.add('is-extra'));
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'show-more-btn';
    btn.textContent = `+ Show ${rows.length - threshold} more`;
    btn.addEventListener('click', () => {
      const nowShown = container.querySelectorAll('.checkbox-row.is-extra.is-shown').length === 0;
      rows.slice(threshold).forEach((row) => row.classList.toggle('is-shown', nowShown));
      btn.textContent = nowShown ? 'Show less' : `+ Show ${rows.length - threshold} more`;
    });
    container.after(btn);
  }
  setupShowMore('category-filters');
  setupShowMore('tag-filters');

  function getActiveFilters(): FilterEntry[] {
    const cats = [...categoryCheckboxes]
      .filter((c) => c.checked)
      .map((c) => ({ type: 'category' as const, value: c.value, label: c.dataset.label || c.value }));
    const tags = [...tagCheckboxes]
      .filter((c) => c.checked)
      .map((c) => ({ type: 'tag' as const, value: c.value, label: c.dataset.label || c.value }));
    return [...cats, ...tags];
  }

  function renderChips() {
    if (!activeChipsContainer) return;
    const active = getActiveFilters();
    activeChipsContainer.innerHTML = '';
    active.forEach((f) => {
      const chip = document.createElement('span');
      chip.className = 'active-chip';
      chip.innerHTML = `${f.label} <button type="button" aria-label="Remove filter">✕</button>`;
      chip.querySelector('button')?.addEventListener('click', () => {
        const source = f.type === 'category' ? categoryCheckboxes : tagCheckboxes;
        source.forEach((c) => { if (c.value === f.value) c.checked = false; });
        applyFilters();
      });
      activeChipsContainer.appendChild(chip);
    });

    if (filterBadge) {
      filterBadge.hidden = active.length === 0;
      filterBadge.textContent = String(active.length);
    }
  }

  function applyFilters() {
    const query = searchInput.value.trim().toLowerCase();
    const activeCategories = [...categoryCheckboxes].filter((c) => c.checked).map((c) => c.value);
    const activeTags = [...tagCheckboxes].filter((c) => c.checked).map((c) => c.value);

    let visibleCount = 0;

    cards.forEach((card) => {
      const title = card.dataset.title || '';
      const description = card.dataset.description || '';
      const category = card.dataset.category || '';
      const tags = (card.dataset.tags || '').split(',').filter(Boolean);

      const matchesSearch = !query || title.includes(query) || description.includes(query);
      const matchesCategory = activeCategories.length === 0 || activeCategories.includes(category);
      const matchesTags = activeTags.length === 0 || activeTags.every((t) => tags.includes(t));

      const show = matchesSearch && matchesCategory && matchesTags;
      card.classList.toggle('is-hidden', !show);
      if (show) visibleCount++;
    });

    if (resultsCount) {
      resultsCount.textContent = `Showing ${visibleCount} of ${cards.length} article${cards.length === 1 ? '' : 's'}`;
    }
    if (noResults) noResults.hidden = visibleCount !== 0;

    renderChips();
  }

  searchInput.addEventListener('input', applyFilters);
  categoryCheckboxes.forEach((cb) => cb.addEventListener('change', applyFilters));
  tagCheckboxes.forEach((cb) => cb.addEventListener('change', applyFilters));

  clearBtn?.addEventListener('click', () => {
    searchInput.value = '';
    categoryCheckboxes.forEach((cb) => (cb.checked = false));
    tagCheckboxes.forEach((cb) => (cb.checked = false));
    applyFilters();
  });

  doneBtn?.addEventListener('click', () => { filterDropdown.open = false; });

  document.addEventListener('click', (e) => {
    if (filterDropdown.open && !filterDropdown.contains(e.target as Node)) {
      filterDropdown.open = false;
    }
  });

  applyFilters();
</script>
