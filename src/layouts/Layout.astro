---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = "The Psychology Square — individual and couples therapy, online and in person in Johar Town, Lahore." } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — The Psychology Square</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>
<body>

<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="wordmark">
      <span class="mark" aria-hidden="true">
        <span class="mark-sq mark-sq--1"></span>
        <span class="mark-sq mark-sq--2"></span>
      </span>
      The Psychology&nbsp;Square
    </a>

    <nav class="site-nav" aria-label="Primary">
      <div class="nav-item">
        <a href="/articles">Articles</a>
        <div class="mega-panel">
          <a href="/articles/category/anxiety">Anxiety</a>
          <a href="/articles/category/depression">Depression</a>
          <a href="/articles/category/adhd">ADHD</a>
          <a href="/articles/category/addiction-recovery">Addiction &amp; Recovery</a>
          <a href="/articles/category/trauma">Trauma</a>
          <a href="/articles/category/relationships">Relationships</a>
          <a href="/articles/category/stress-burnout">Stress &amp; Burnout</a>
          <a href="/articles">View all articles →</a>
        </div>
      </div>
      <div class="nav-item"><a href="/resources">Resources</a></div>
      <div class="nav-item"><a href="/#team">Our Team</a></div>
      <div class="nav-item"><a href="/#contact">Contact</a></div>
    </nav>

    <a href="/#contact" class="header-cta">Book a session</a>
  </div>
</header>

<main>
  <slot />
</main>

<footer class="site-footer">
  <div class="wrap footer-inner">
    <span>© {new Date().getFullYear()} The Psychology Square</span>
    <span>Johar Town, Lahore, Pakistan — Online &amp; in-person sessions</span>
  </div>
</footer>

</body>
</html>
